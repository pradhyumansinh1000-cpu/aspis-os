# ─── Application ──────────────────────────────────────────────────────────────
APP_NAME="StudentAI Platform"
APP_ENV=development          # development | staging | production
DEBUG=true
SECRET_KEY=your-super-secret-key-change-in-production-minimum-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── Database ─────────────────────────────────────────────────────────────────
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_USER=studentai
POSTGRES_PASSWORD=strongpassword123
POSTGRES_DB=studentai_db
# Constructed by config.py — do not set manually
# DATABASE_URL=postgresql+asyncpg://...

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ─── File Storage ─────────────────────────────────────────────────────────────
STORAGE_BACKEND=local         # local | s3
LOCAL_UPLOAD_DIR=/app/uploads
# AWS (only if STORAGE_BACKEND=s3)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_BUCKET_NAME=studentai-uploads
AWS_REGION=us-east-1

# ─── AI Models ────────────────────────────────────────────────────────────────
# Llama 70B via Ollama (self-hosted, zero API cost)
OLLAMA_BASE_URL=http://ollama:11434
LLAMA_MODEL=llama3:70b

# NVIDIA Nemotron Embed (via local inference or NVIDIA API)
NEMOTRON_MODEL=nvidia/llama-3.2-nv-embedqa-1b-v2
NEMOTRON_BASE_URL=http://nemotron:8000   # or https://integrate.api.nvidia.com/v1
NVIDIA_API_KEY=                           # only needed for NVIDIA cloud

# Whisper (local speech-to-text)
WHISPER_MODEL=base                        # tiny | base | small | medium | large
WHISPER_DEVICE=cpu                        # cpu | cuda

# OCR
OCR_ENGINE=paddleocr                     # paddleocr | tesseract | both

# ─── Celery ───────────────────────────────────────────────────────────────────
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ─── CORS ─────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# ─── Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_AI_PER_MINUTE=10

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=json                           # json | text
